{
  "name": "fabrica17-template",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles/tokens.css": "./dist/styles/tokens.css"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "svelte": "./dist/index.js",
  "scripts": {
    "dev": "vite dev",
    "tokens:sync": "bun scripts/sync-tokens.ts",
    "build": "vite build",
    "build:lib": "svelte-package",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "clean:template": "bun run scripts/clean-template.ts",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.104",
    "@iconify-json/mynaui": "^1.2.17",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.9.1",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.7"
  },
  "description": "Template base premium para proyectos de la agencia. Incluye sistema de diseño, utilidades globales, componentes interactivos y governance."
}
